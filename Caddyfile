expense-sync-bot.invntrm.ru {
	# Automatic HTTPS with Let's Encrypt

	# Static pages: homepage, privacy policy, terms of service
	handle / {
		root * /var/www/ExpenseSyncBot/public
		rewrite * /index.html
		file_server
	}

	handle /privacy {
		root * /var/www/ExpenseSyncBot/public
		rewrite * /privacy-policy.html
		file_server
	}

	handle /terms {
		root * /var/www/ExpenseSyncBot/public
		rewrite * /terms-of-service.html
		file_server
	}

	# All proxied endpoints — retry during PM2 reload so clients see a delay, not 502.
	# Caddy holds the connection and retries every 500ms for up to 10s.
	@backend path /callback* /health /api/*
	handle @backend {
		reverse_proxy localhost:3311 {
			lb_try_duration 10s
			lb_try_interval 500ms
		}
	}

	# Temporary images for OCR processing
	handle /temp-images/* {
		root * /var/www/ExpenseSyncBot
		file_server
	}

	# Everything else
	handle {
		respond "Not Found" 404
	}

	# Logging
	log {
		output file /var/log/caddy/expensesyncbot.log
		format console
	}
}

expense-sync-bot-app.invntrm.ru {
	# Mini App frontend (Vite build)
	root * /var/www/ExpenseSyncBot/miniapp/dist
	file_server

	# SPA fallback — serve index.html for client-side routing
	try_files {path} /index.html

	# API requests proxied to the Bun server — retry during PM2 reload
	handle /api/* {
		reverse_proxy localhost:3311 {
			lb_try_duration 10s
			lb_try_interval 500ms
		}
	}

	log {
		output file /var/log/caddy/miniapp.log
		format console
	}
}
