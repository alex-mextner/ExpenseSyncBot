# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_from_botfather
BOT_USERNAME=ExpenseSyncBot

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3311/callback

# Mini App (optional — enables web_app buttons in bot)
# MINIAPP_URL=https://expense-sync-bot-app.invntrm.ru

# Google OAuth (legacy) — for users who connected before GCP project migration
# Optional: if absent, legacy token refresh will fail and user must /reconnect
# GOOGLE_LEGACY_CLIENT_ID=old_google_client_id
# GOOGLE_LEGACY_CLIENT_SECRET=old_google_client_secret

# OAuth Server
OAUTH_SERVER_PORT=3311

# Database
DATABASE_PATH=./data/expenses.db

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# Environment
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# AI providers — all OpenAI-compatible (via OpenAI SDK)
#
# Chains:
#   SMART_CHAIN: z.ai AI_MODEL       → Gemini GEMINI_MODEL       → HF HF_MODEL
#   FAST_CHAIN:  z.ai AI_FAST_MODEL  → Gemini GEMINI_FAST_MODEL  → HF HF_FAST_MODEL
#   OCR_CHAIN:   Gemini GEMINI_VISION_MODEL → HF HF_VISION_MODEL
#
# All AI fields below are REQUIRED — no hardcoded defaults.
# ─────────────────────────────────────────────────────────────────────────────

# z.ai API key (OpenAI-compat coding endpoint)
# Historical name ANTHROPIC_API_KEY — it's actually the z.ai key.
# Get one at https://z.ai/manage-apikey/apikey-list
ANTHROPIC_API_KEY=your_zai_api_key
AI_BASE_URL=https://api.z.ai/api/coding/paas/v4
AI_MODEL=glm-5.1
AI_FAST_MODEL=glm-4.5-flash

# HuggingFace Router (text fallback + vision fallback)
HF_TOKEN=hf_XXX
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=Qwen/Qwen3-235B-A22B
HF_FAST_MODEL=meta-llama/Llama-3.3-70B-Instruct
HF_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# Google Gemini (text fallback + vision primary)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# AI debug logs — full conversation logs to logs/chats/{chatId}/
# AI_DEBUG_LOGS=true

# GitHub (fine-grained PAT for dev pipeline PR operations)
GITHUB_TOKEN=github_pat_XXX

# Admin Telegram user ID — for merchant rule approval cards + deploy/healthcheck alerts (optional)
# If absent, AI merchant rule generation is disabled (no crash on startup)
# BOT_ADMIN_CHAT_ID=

# Large transaction threshold in EUR (default: 100)
# LARGE_TX_THRESHOLD_EUR=100
